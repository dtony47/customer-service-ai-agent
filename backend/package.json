{
  "name": "customer-service-ai-backend",
  "version": "1.0.0",
  "description": "Customer Service AI Agent Backend",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:init": "tsx src/db/schema.ts",
    "db:setup": "tsx src/db/setup.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:rollback": "tsx src/db/rollback.ts",
    "worker": "tsx src/workers/index.ts"
  },
  "keywords": [
    "customer-service",
    "ai",
    "chatbot",
    "slack",
    "whatsapp",
    "email",
    "voice"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "0.11.0",
    "@slack/bolt": "3.17.0",
    "@slack/web-api": "6.11.0",
    "axios": "1.7.7",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.18.2",
    "express-async-errors": "3.1.1",
    "jsonwebtoken": "9.0.2",
    "nodemailer": "6.9.7",
    "pg": "8.11.3",
    "socket.io": "4.7.2",
    "stripe": "14.17.0",
    "twilio": "4.20.0",
    "uuid": "9.0.1",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "@vitest/ui": "^1.6.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.17.0",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
