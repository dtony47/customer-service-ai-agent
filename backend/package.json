{
  "name": "customer-service-ai-backend",
  "version": "1.0.0",
  "description": "Customer Service AI Agent Backend",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:setup": "tsx src/db/setup.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:rollback": "tsx src/db/rollback.ts"
  },
  "keywords": [
    "customer-service",
    "ai",
    "chatbot",
    "slack",
    "whatsapp",
    "email",
    "voice"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/generative-language": "^2.0.0",
    "@google/generative-ai": "^0.7.2",
    "@slack/bolt": "^3.17.1",
    "@slack/web-api": "^6.11.1",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "nodemailer": "^6.9.8",
    "pg": "^8.12.0",
    "socket.io": "^4.7.2",
    "twilio": "^4.20.3",
    "uuid": "^9.0.1",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/nodemailer": "^6.4.14",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.17.0",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
